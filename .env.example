# NexBank — .env konfiguratsiya
# Bu faylni .env deb nusxalang va qiymatlarni to'ldiring

SECRET_KEY=nexbank-sizning-maxfiy-kalit-bu-yerni-o'zgartiring-2024

# Port (WebDock VPS uchun)
PORT=8000

# Gemini AI API (https://aistudio.google.com dan oling)
GEMINI_API_KEY=your_gemini_api_key_here

# Email (OTP yuborish uchun — Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sizning_email@gmail.com
SMTP_PASS=gmail_app_password_bu_yerga
SMTP_FROM=sizning_email@gmail.com

# Eslatma: Gmail App Password olish uchun:
# Google Account → Security → 2-Step Verification → App passwords
